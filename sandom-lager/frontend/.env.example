# Frontend environment variables for local development
# Copy this to .env and fill in with your values

# Auth0 Configuration - Get these from your Auth0 dashboard
# Applications > Your App > Settings
VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_AUDIENCE=https://sandom-api

# API Base URL - Backend server location
# Local dev: http://localhost:5000
# Docker Compose: http://backend:5000
# Production/Render: https://your-backend.onrender.com
VITE_API_BASE_URL=http://localhost:5000

# Optional Supabase Realtime (for real-time updates in future)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Vite HMR Configuration (optional, for Docker networking)
# If WebSocket HMR fails in Docker, uncomment and set these:
# VITE_HMR_HOST=localhost
# VITE_HMR_HOST=host.docker.internal  (Docker Desktop)
# VITE_HMR_PORT=5173

PORT=